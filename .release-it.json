{
  "git": {
    "commitMessage": "chore(app): update to v${version}",
    "requireBranch": "main",
    "tagName": "preview/v${version}"
  },
  "github": {
    "release": false
  },
  "hooks": {
    "after:bump": "bunx auto-changelog -v preview/v${version}",
    "before:init": ["git pull", "bun biome ci ."]
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/bumper": {
      "out": ["./app.config.ts"]
    }
  }
}
