{
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "colorize.decoration_type": "square-dot",
  "colorize.languages": [
    "css",
    "sass",
    "scss",
    "less",
    "postcss",
    "sss",
    "stylus",
    "xml",
    "svg",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "cSpell.ignoreRegExpList": ["/from\\\\s+(['\\\"]).*\\\\1/"],
  "cSpell.ignoreWords": [
    "actionsheet",
    "biomejs",
    "commitlint",
    "dayjs",
    "echarts",
    "hookform",
    "nativewind",
    "pressable",
    "pressables",
    "radash",
    "shopify",
    "supabase",
    "tailwindcss",
    "upsert",
    "zustand",
    "heroui",
    "uniwind"
  ],
  "cSpell.words": ["aurebesh", "sabersprops"],
  "editor.codeActionsOnSave": {
    "source.action.noDuplicateClasses.biome": "explicit",
    "source.action.useSortedAttributes.biome": "explicit",
    "source.action.useSortedEnumMembers.biome": "explicit",
    "source.action.useSortedInterfaceMembers.biome": "explicit",
    "source.action.useSortedKeys.biome": "explicit",
    "source.action.useSortedProperties.biome": "explicit",
    "source.action.useSortedSelectionSet.biome": "explicit",
    "source.action.useSortedTypeFields.biome": "explicit",
    "source.fixAll": "explicit",
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.tabSize": 2,
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 120,
  "explorer.fileNesting.patterns": {
    "app.config.ts": "*.env, babel.config.*, eas.*, metro.config.*, tailwind*, tsconfig*",
    "package.json": "bun.*, .release-it*, .auto-changelog, biome.*, .prettier*, commitlint.*",
    "README.md": "CHANGELOG.md, LICENSE*, CONTRIBUTING.md, CODE_OF_CONDUCT.md, SECURITY.md, AUDIT.md, CLAUDE.md"
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "js/ts.updateImportsOnFileMove.enabled": "always"
}
